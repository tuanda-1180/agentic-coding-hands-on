# Target launch moment for the prelaunch countdown (ISO 8601, with timezone offset).
# If unset or invalid, the app counts down COUNTDOWN_DURATION_SECONDS (default 7s) from
# page load — see app/lib/countdown-config.ts.
NEXT_PUBLIC_LAUNCH_DATE="2026-12-31T00:00:00+07:00"

# Auth.js v5 secret — required for JWT signing/encryption.
# Generate: openssl rand -base64 32
AUTH_SECRET=

# Demo seed credentials (development only — not real accounts):
#   Regular user:  user@sun.example / user1234
#   Admin user:    admin@sun.example / admin1234
